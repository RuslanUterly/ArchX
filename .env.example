POSTGRES_DB=archx
POSTGRES_USER=archx
POSTGRES_PASSWORD=change_me

# Minimum 32 chars
JWT_SECRET=replace_with_a_strong_secret_key_32_plus_chars

# Public domain for HTTPS (example: archx.example.com)
APP_DOMAIN=archx.example.com
ACME_EMAIL=admin@example.com

# Browser-visible base URL (without /api, backend is proxied by Caddy at /api/*)
VITE_API_URL=https://archx.example.com

# Link used in password-reset emails (frontend route)
RESET_PASSWORD_URL=https://archx.example.com/auth/reset-password

# SMTP settings for sending password reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USER=smtp_user
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=ArchX
